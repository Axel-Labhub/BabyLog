<!--pages/settings/settings.wxml-->
<view class="page">
  <!-- 数据统计 -->
  <view class="section stats-section">
    <view class="section-header">
      <text class="section-title">数据统计</text>
    </view>
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">👶</text>
        <text class="stat-value">{{babyCount}}</text>
        <text class="stat-label">宝宝数量</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">📝</text>
        <text class="stat-value">{{totalRecords}}</text>
        <text class="stat-label">总记录数</text>
      </view>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">数据管理</text>
    </view>
    <view class="setting-list">
      <view class="setting-item" bindtap="exportData">
        <view class="setting-icon">📤</view>
        <view class="setting-content">
          <text class="setting-name">导出数据</text>
          <text class="setting-desc">导出所有记录为 JSON 文件</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="clearData">
        <view class="setting-icon">🗑️</view>
        <view class="setting-content">
          <text class="setting-name">清除本地缓存</text>
          <text class="setting-desc">清除本地存储的设置信息</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 显示设置 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">显示设置</text>
    </view>
    <view class="setting-list">
      <view class="setting-item">
        <view class="setting-icon">🌙</view>
        <view class="setting-content">
          <text class="setting-name">夜间模式</text>
          <text class="setting-desc">凌晨护眼，减少刺眼</text>
        </view>
        <switch checked="{{darkMode}}" bindchange="toggleDarkMode" color="#FF9500" />
      </view>
      <view class="setting-item">
        <view class="setting-icon">🔔</view>
        <view class="setting-content">
          <text class="setting-name">喂奶提醒</text>
          <text class="setting-desc">超过{{reminderInterval}}小时未喂奶时提醒</text>
        </view>
        <switch checked="{{feedReminder}}" bindchange="toggleFeedReminder" color="#FF9500" />
      </view>
    </view>
  </view>

  <!-- 提醒时间设置 -->
  <view class="section" wx:if="{{feedReminder}}">
    <view class="section-header">
      <text class="section-title">提醒间隔</text>
    </view>
    <view class="interval-options">
      <view class="interval-option {{reminderInterval === 2 ? 'active' : ''}}"
            bindtap="setReminderInterval" data-interval="2">
        <text>2小时</text>
      </view>
      <view class="interval-option {{reminderInterval === 3 ? 'active' : ''}}"
            bindtap="setReminderInterval" data-interval="3">
        <text>3小时</text>
      </view>
      <view class="interval-option {{reminderInterval === 4 ? 'active' : ''}}"
            bindtap="setReminderInterval" data-interval="4">
        <text>4小时</text>
      </view>
    </view>
  </view>

  <!-- 声音与震动 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">声音与震动</text>
    </view>
    <view class="setting-list">
      <view class="setting-item">
        <view class="setting-icon">🔊</view>
        <view class="setting-content">
          <text class="setting-name">提示音</text>
          <text class="setting-desc">记录完成时播放提示音</text>
        </view>
        <switch checked="{{soundEnabled}}" bindchange="toggleSound" color="#FF9500" />
      </view>
      <view class="setting-item">
        <view class="setting-icon">📳</view>
        <view class="setting-content">
          <text class="setting-name">震动反馈</text>
          <text class="setting-desc">记录完成时震动反馈</text>
        </view>
        <switch checked="{{vibrationEnabled}}" bindchange="toggleVibration" color="#FF9500" />
      </view>
    </view>
  </view>

  <!-- 其他设置 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">其他设置</text>
    </view>
    <view class="setting-list">
      <view class="setting-item">
        <view class="setting-icon">☁️</view>
        <view class="setting-content">
          <text class="setting-name">自动同步</text>
          <text class="setting-desc">自动同步数据到云端</text>
        </view>
        <switch checked="{{autoSync}}" bindchange="toggleAutoSync" color="#FF9500" />
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">关于</text>
    </view>
    <view class="setting-list">
      <view class="setting-item">
        <view class="setting-icon">📱</view>
        <view class="setting-content">
          <text class="setting-name">版本</text>
          <text class="setting-desc">V2.1 小程序版</text>
        </view>
      </view>
      <view class="setting-item" bindtap="checkUpdate">
        <view class="setting-icon">🔄</view>
        <view class="setting-content">
          <text class="setting-name">检查更新</text>
          <text class="setting-desc">检查是否有新版本</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="showFeedback">
        <view class="setting-icon">💬</view>
        <view class="setting-content">
          <text class="setting-name">反馈建议</text>
          <text class="setting-desc">帮助我们改进产品</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="goToPrivacy">
        <view class="setting-icon">🔒</view>
        <view class="setting-content">
          <text class="setting-name">隐私政策</text>
          <text class="setting-desc">了解我们的隐私保护</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 用户信息 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">用户信息</text>
    </view>
    <view class="user-info">
      <text class="user-id">用户 ID: {{userId}}</text>
      <text class="user-hint">此 ID 用于识别您的记录，无需登录</text>
    </view>
  </view>
</view>
