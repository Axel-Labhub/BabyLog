/* pages/baby/baby.wxss */

.page {
  min-height: 100vh;
  background-color: var(--bg);
  padding: 24rpx;
}

/* 区块 */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.member-count {
  font-size: 24rpx;
  color: var(--text2);
}

/* 宝宝卡片 */
.baby-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--card);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.baby-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(255, 149, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-icon {
  font-size: 40rpx;
}

.baby-info {
  flex: 1;
}

.baby-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.baby-birth {
  font-size: 24rpx;
  color: var(--text2);
  margin-top: 4rpx;
}

.baby-actions {
  display: flex;
}

.action-edit {
  font-size: 26rpx;
  color: var(--feed);
  padding: 8rpx 20rpx;
  background-color: rgba(255, 149, 0, 0.1);
  border-radius: 16rpx;
}

/* 分享区块 */
.share-section {
  margin-top: 24rpx;
}

.share-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--card);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.share-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.share-content {
  flex: 1;
}

.share-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
}

.share-desc {
  font-size: 24rpx;
  color: var(--text2);
  margin-top: 4rpx;
}

.share-arrow {
  font-size: 32rpx;
  color: var(--text3);
}

/* 成员列表 */
.members-section {
  margin-top: 24rpx;
}

.member-list {
  background-color: var(--card);
  border-radius: 16rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 28rpx;
  color: var(--text);
}

.member-role {
  font-size: 24rpx;
  color: var(--text2);
  margin-top: 2rpx;
}

/* 宝宝列表 */
.baby-list {
  background-color: var(--card);
  border-radius: 16rpx;
}

.baby-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.baby-item:last-child {
  border-bottom: none;
}

.switch-arrow {
  font-size: 32rpx;
  color: var(--text3);
}

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-content {
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text2);
  margin-bottom: 48rpx;
}

.empty-actions {
  display: flex;
  gap: 24rpx;
}

.btn-create {
  padding: 24rpx 48rpx;
  background-color: var(--feed);
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-join {
  padding: 24rpx 48rpx;
  background-color: var(--bg);
  color: var(--text);
  border: 2rpx solid var(--border);
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-overlay.hidden {
  display: none;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: var(--card);
  border-radius: 24rpx;
  overflow: hidden;
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.modal-body {
  padding: 32rpx;
}

.modal-hint {
  font-size: 28rpx;
  color: var(--text2);
  text-align: center;
  display: block;
}

.qr-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  margin-top: 24rpx;
  background-color: var(--bg);
  border-radius: 16rpx;
}

.qr-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.qr-text {
  font-size: 28rpx;
  color: var(--text);
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid var(--border);
}

.modal-btn {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  color: var(--text2);
  border-right: 1rpx solid var(--border);
}

.modal-btn.confirm {
  color: var(--feed);
}

.modal-btn.delete {
  color: var(--danger);
  border-right: 1rpx solid var(--border);
}

/* 表单 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text2);
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
}

.picker-value {
  color: var(--text);
}

.picker-arrow {
  color: var(--text3);
  font-size: 32rpx;
}

/* 小程序码弹窗 */
.qr-modal {
  max-width: 640rpx;
}

.qr-container {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.qr-image {
  width: 400rpx;
  height: 400rpx;
  border-radius: 16rpx;
}

.qr-loading {
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text2);
}