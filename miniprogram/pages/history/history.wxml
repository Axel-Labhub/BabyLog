<!--pages/history/history.wxml-->
<view class="page">
  <view class="date-selector">
    <view class="date-btn" bindtap="prevWeek">
      <text>‹</text>
    </view>
    <view class="date-range">
      <text>{{startDate}} - {{endDate}}</text>
    </view>
    <view class="date-btn" bindtap="nextWeek">
      <text>›</text>
    </view>
  </view>

  <view class="week-stats">
    <view class="stat-item">
      <text class="stat-icon">🍼</text>
      <text class="stat-value text-feed">{{weekStats.feedCount}}</text>
      <text class="stat-label">喂奶次数</text>
    </view>
    <view class="stat-item">
      <text class="stat-icon">⏱️</text>
      <text class="stat-value text-feed">{{weekStats.feedTotal}}</text>
      <text class="stat-label">喂奶总时长</text>
    </view>
    <view class="stat-item">
      <text class="stat-icon">😴</text>
      <text class="stat-value text-sleep">{{weekStats.sleepTotal}}</text>
      <text class="stat-label">睡眠总时长</text>
    </view>
    <view class="stat-item">
      <text class="stat-icon">👶</text>
      <text class="stat-value text-poop">{{weekStats.diaperCount}}</text>
      <text class="stat-label">换尿布</text>
    </view>
    <view class="stat-item" wx:if="{{weekStats.tempCount > 0}}">
      <text class="stat-icon">🌡️</text>
      <text class="stat-value text-temp">{{weekStats.tempCount}}</text>
      <text class="stat-label">体温记录</text>
    </view>
    <view class="stat-item" wx:if="{{weekStats.medCount > 0}}">
      <text class="stat-icon">💊</text>
      <text class="stat-value text-medicine">{{weekStats.medCount}}</text>
      <text class="stat-label">用药记录</text>
    </view>
  </view>

  <view class="charts-section">
    <chart-bar 
      title="喂奶次数趋势" 
      subtitle="本周" 
      :data="feedChartData" 
      color="#FF9500" 
      unit="次"
    />
    <chart-line 
      title="睡眠时长趋势" 
      subtitle="本周" 
      :data="sleepChartData" 
      color="#8B5CF6" 
      unit="分"
    />
  </view>

  <view class="daily-list">
    <view class="day-section" wx:for="{{dailyRecords}}" wx:key="date">
      <view class="day-header">
        <text class="day-date">{{item.formattedDate}}</text>
        <text class="day-count">{{item.records.length}} 条记录</text>
      </view>

      <view class="day-stats">
        <view class="mini-stat" wx:if="{{item.stats.feedCount > 0}}">
          <text class="mini-icon">🍼</text>
          <text class="mini-value">{{item.stats.feedCount}}次 {{item.stats.feedDuration}}</text>
        </view>
        <view class="mini-stat" wx:if="{{item.stats.sleepDuration}}">
          <text class="mini-icon">😴</text>
          <text class="mini-value">{{item.stats.sleepDuration}}</text>
        </view>
        <view class="mini-stat" wx:if="{{item.stats.diaperCount > 0}}">
          <text class="mini-icon">👶</text>
          <text class="mini-value">{{item.stats.diaperCount}}次</text>
        </view>
        <view class="mini-stat" wx:if="{{item.stats.tempCount > 0}}">
          <text class="mini-icon">🌡️</text>
          <text class="mini-value">{{item.stats.tempCount}}次</text>
        </view>
        <view class="mini-stat" wx:if="{{item.stats.medCount > 0}}">
          <text class="mini-icon">💊</text>
          <text class="mini-value">{{item.stats.medCount}}次</text>
        </view>
      </view>

      <view class="record-list" wx:if="{{item.records.length > 0}}">
        <view class="record-item" wx:for="{{item.records}}" wx:key="id" wx:for-item="record">
          <view class="record-time">{{record.time}}</view>
          <view class="record-dot {{record.type}}"></view>
          <view class="record-content">
            <text class="record-icon">{{record.icon}}</text>
            <text class="record-title">{{record.title}}</text>
            <text class="record-detail">{{record.detail}}</text>
          </view>
          <view class="record-delete" catchtap="deleteRecord" data-id="{{record.id}}">
            <text>×</text>
          </view>
        </view>
      </view>

      <view class="empty-day" wx:else>
        <text class="empty-text">无记录</text>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <view class="loading-dots">
      <view class="dot"></view>
      <view class="dot"></view>
      <view class="dot"></view>
    </view>
  </view>
</view>
