/* pages/history/history.wxss */

.page {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: 40rpx;
}

/* 日期选择 */
.date-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background-color: var(--card);
  border-bottom: 1rpx solid var(--border);
}

.date-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--text2);
}

.date-range {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: var(--text);
}

/* 周统计 */
.week-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background-color: var(--card);
  border-radius: 16rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text2);
}

/* 每日记录 */
.daily-list {
  padding: 0 24rpx;
}

.day-section {
  margin-bottom: 24rpx;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.day-date {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.day-count {
  font-size: 24rpx;
  color: var(--text2);
}

.day-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.mini-stat {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background-color: var(--card);
  border-radius: 12rpx;
}

.mini-icon {
  font-size: 20rpx;
  margin-right: 6rpx;
}

.mini-value {
  font-size: 24rpx;
  color: var(--text2);
}

.record-list {
  background-color: var(--card);
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 24rpx;
  color: var(--text3);
  width: 80rpx;
  flex-shrink: 0;
}

.record-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.record-dot.feed { background-color: var(--feed); }
.record-dot.sleep { background-color: var(--sleep); }
.record-dot.diaper { background-color: var(--pee); }

.record-content {
  flex: 1;
  display: flex;
  align-items: center;
}

.record-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.record-title {
  font-size: 26rpx;
  color: var(--text);
  margin-right: 8rpx;
}

.record-detail {
  font-size: 24rpx;
  color: var(--text2);
}

.empty-day {
  padding: 24rpx;
  background-color: var(--card);
  border-radius: 16rpx;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
  color: var(--text3);
}