/* components/chart-bar/chart-bar.wxss */
.chart-card {
  background-color: var(--card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.chart-subtitle {
  font-size: 24rpx;
  color: var(--text3);
}

.chart-body {
  display: flex;
  height: 300rpx;
}

.chart-y-axis {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 16rpx;
  width: 60rpx;
}

.y-label {
  font-size: 20rpx;
  color: var(--text3);
  text-align: right;
}

.chart-area {
  flex: 1;
  position: relative;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.grid-line {
  height: 1rpx;
  background-color: var(--border-light);
}

.chart-bars {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 40rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  width: 32rpx;
  height: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.bar {
  width: 100%;
  border-radius: 16rpx 16rpx 0 0;
  transition: height 0.3s ease;
  min-height: 4rpx;
}

.bar-label {
  font-size: 18rpx;
  color: var(--text3);
  margin-top: 12rpx;
}

.bar-value {
  font-size: 20rpx;
  color: var(--text2);
  margin-top: 4rpx;
}
